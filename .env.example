# Firecrawl API key — get one at https://firecrawl.dev
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxx

# Optional: default target Miro board id (overridden by --board on the CLI).
# From a board URL like
#   https://miro.com/app/board/uXjVKabc1234=/
# the id is the part between `/board/` and the trailing `/` (with the `=`).
MIRO_BOARD_ID=uXjVKabc1234=

# Optional: override the Miro MCP server URL.
# MIRO_MCP_URL=https://mcp.miro.com/

# Note: Miro auth uses OAuth 2.1 — no token in this file. On first run a
# browser tab opens for consent; tokens are cached to
# ~/.config/crwl/tokens.json.
